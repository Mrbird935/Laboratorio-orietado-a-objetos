int x[] = new int[10];
int y[] = new int[10];
int indice = 0;
int c= 0;
void setup() {

  size(800, 600);
  strokeWeight(2);
}

void draw() {
  background(222, 99, 22);
  for (int i=0; i<c; i++) {
    ellipse(x[i], y[i], 100, 100);
  }
}
void mousePressed() {
  x[indice]=mouseX;
  y[indice]=mouseY;
  indice++;
  if (indice>=10) {
    indice=0;
  }
  if (c<10) {
    c++;
  }
}
