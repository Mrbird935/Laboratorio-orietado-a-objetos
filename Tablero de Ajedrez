int c = 8;
int f = 8;

void setup() {

  size(600, 600);
  background(222, 99, 22);
  stroke(3);
}

void draw() {

  float Ancho = width/c;
  float Alto = height/c;
  for (int i=0; i < c; i++) {
    for (int j=0; j < f; j++) {


      float x = j*Ancho;
      float y = i*Alto;
      if ((i + j) % 2 == 0) {
        fill(255);
      } else {
        fill(0);
      }
      rect(x, y, Ancho, Alto);
    }
  }
}
