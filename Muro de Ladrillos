int c = 10;
int f = 10;

void setup() {
  size(800, 600);
  background(255);
}

void draw() {
  float Ancho = width/c;
  float Alto = height/f;

  for (int i=0; i < f; i++) {
    for (int j=0; j < c; j++) {

      float x = j * Ancho;
      float y = i * Alto;
    
      if (i % 2 != 0) {
        x = x + (Ancho / 2);
      }


      rect(x, y, Ancho, Alto);
    }
  }
}
