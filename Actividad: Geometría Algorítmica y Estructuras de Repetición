int cant = 10;
int sepx, sepy;

void setup() {

  size(800, 600);
  sepx = width/cant;
  sepy = height/cant;
}

void draw() {
  background(255);
  for (int i=0; i < cant; i++) {
    //Vertice Izquierdo Inferior
    line(0, i*sepy, i*sepx, height);
    //Vertice Derecho Inferior
    line(width, height-i*sepy, i*sepx, height);
    //Vertice Derecho Superior
    line(width, height-i*sepy, width-i*sepx, 0);
    //Vertice Izquierdo Superior
    line(0, i*sepy, width-i*sepx, 0);
  }
}
