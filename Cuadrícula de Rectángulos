int c = 10;
int f = 10;

void setup() {

  size(800, 600);
  background(222, 99, 22);
}

void draw() {

  for (int i=0; i < c; i++) {
    for (int j=0; j < f; j++) {

      float Ancho = width/c;
      float Alto = height/c;
      float x = j*Ancho;
        float y = i*Alto;
        rect(x, y, Ancho, Alto);
    }
  }
}
